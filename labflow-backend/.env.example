PORT=5000

# Local example:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/labflow_db

# Production example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Use a long random secret in real environments.
# Do not reuse this placeholder.
JWT_SECRET=replace_with_a_long_random_secret

# Use development locally and production on deployed backend.
NODE_ENV=development

# Local frontend:
# FRONTEND_URL=http://localhost:5173

# Production frontend:
# FRONTEND_URL=https://your-frontend-domain.com

FRONTEND_URL=http://localhost:5173